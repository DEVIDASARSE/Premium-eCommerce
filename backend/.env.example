## Example environment variables for the server
# NOTE: Do NOT commit real secrets. Copy this file to `server/.env` and fill values locally.

# MongoDB connection string (use a production URI in production)
MONGO_URI=mongodb://localhost:27017/reimagine

# Secret used to sign JWTs. Use a long, random string in production.
JWT_SECRET=your_jwt_secret_here

# Server port
PORT=5000

# Admin secret used for creating initial admin user (keep private)
ADMIN_SECRET=your_admin_secret_here

# Optional third-party service keys (placeholders)
STRIPE_SECRET_KEY=your_stripe_secret_key
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email (SMTP) settings for transactional emails
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_email_user
EMAIL_PASS=your_email_password
